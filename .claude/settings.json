{
  "enabledPlugins": {
    "github@claude-plugins-official": true,
    "reka@reka-plugins": true
  },
  "extraKnownMarketplaces": {
    "reka-plugins": {
      "source": {
        "source": "github",
        "repo": "getreka/reka-plugin"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(npm run build:*)",
      "Bash(npm run test:*)",
      "Bash(npx vitest:*)",
      "Bash(npx prettier:*)",
      "Bash(npx eslint:*)",
      "Bash(docker compose:*)",
      "Bash(curl http://localhost:*)"
    ]
  }
}
