// Rate Limiting
RATE_LIMIT_ENABLED: boolean;
RATE_LIMIT_MAX: number;
RATE_LIMIT_WINDOW_MS: number;
RATE_LIMIT_SKIP_PATHS: string[];

// --- Add to config object ---

// Rate Limiting
RATE_LIMIT_ENABLED: process.env.RATE_LIMIT_ENABLED !== 'false',
