{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (path)",
          "legendFormat": "{{path}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Request Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Active Sessions / Projects",
      "type": "stat",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 0 },
      "targets": [
        { "expr": "platform_active_sessions", "legendFormat": "Sessions" },
        { "expr": "platform_active_projects", "legendFormat": "Projects" }
      ]
    },
    {
      "title": "Embedding Latency",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 7 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(embedding_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Embedding Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 7, "w": 4, "x": 8, "y": 7 },
      "targets": [
        {
          "expr": "rate(embedding_cache_hits_total[5m]) / (rate(embedding_cache_hits_total[5m]) + rate(embedding_cache_misses_total[5m]))",
          "legendFormat": "hit rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "value": 0, "color": "red" },
              { "value": 0.5, "color": "yellow" },
              { "value": 0.8, "color": "green" }
            ]
          }
        }
      }
    },
    {
      "title": "LLM Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 6, "x": 12, "y": 7 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Circuit Breaker",
      "type": "stat",
      "gridPos": { "h": 7, "w": 6, "x": 18, "y": 7 },
      "targets": [
        { "expr": "circuit_breaker_state", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "CLOSED", "color": "green" },
                "1": { "text": "HALF-OPEN", "color": "yellow" },
                "2": { "text": "OPEN", "color": "red" }
              }
            }
          ]
        }
      }
    },
    {
      "title": "Memory Operations",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "rate(memory_operations_total[5m])",
          "legendFormat": "{{operation}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Memory Governance",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "rate(memory_governance_total[5m])",
          "legendFormat": "{{action}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Search Latency",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 21 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(search_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Search Results Count",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 21 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(search_results_count_bucket[5m])) by (le))",
          "legendFormat": "median results"
        }
      ]
    },
    {
      "title": "Graph Edges / Expansion",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 21 },
      "targets": [
        { "expr": "rate(graph_edges_total[5m])", "legendFormat": "edges/s" },
        {
          "expr": "histogram_quantile(0.95, sum(rate(graph_expansion_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "expansion p95"
        }
      ]
    },
    {
      "title": "Consolidation Duration",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rag_event_processing_duration_seconds_bucket{event_type=~\"session:ending\"}[5m])) by (le))",
          "legendFormat": "consolidation p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Event Processing",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "rate(rag_event_emitted_total[5m])",
          "legendFormat": "emitted {{event_type}}"
        },
        {
          "expr": "rate(rag_event_processed_total[5m])",
          "legendFormat": "processed {{event_type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "title": "Actor Mailbox Depth",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 35 },
      "targets": [
        { "expr": "rag_actor_mailbox_depth", "legendFormat": "{{actor_type}}" }
      ]
    },
    {
      "title": "Node.js Memory",
      "type": "timeseries",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 35 },
      "targets": [
        { "expr": "nodejs_heap_size_used_bytes", "legendFormat": "heap used" },
        { "expr": "process_resident_memory_bytes", "legendFormat": "RSS" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["reka", "rag"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Reka RAG Platform",
  "uid": "reka-rag-overview"
}
