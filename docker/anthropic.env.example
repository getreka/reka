# Anthropic credentials + model config for the reka-api container.
#
# Usage: copy to docker/anthropic.env and fill in the key. The compose file loads
# it via an OPTIONAL env_file (required: false) — the stack boots without it
# (Ollama-only, no Anthropic spend). NEVER commit docker/anthropic.env (gitignored).
#
#   cp docker/anthropic.env.example docker/anthropic.env

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
CLAUDE_EFFORT=high

# ── Deferred ops items (uncomment when ready) ────────────────────────────────
# Trust the cloudflared/reverse-proxy hop so rate limiting keys on the real
# client IP instead of the proxy's:
# TRUST_PROXY=1
# Dedicated admin key for /api/keys management (deny-by-default without it):
# ADMIN_API_KEY=
