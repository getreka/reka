{
  "name": "@shared/rag-api",
  "version": "2.1.0",
  "description": "Shared RAG API for multi-project support",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && npm run copy-assets",
    "copy-assets": "cp src/services/parsers/scip.proto dist/services/parsers/ && cp src/services/parsers/queries/*.scm dist/services/parsers/queries/ 2>/dev/null || true",
    "dev": "ts-node src/server.ts",
    "start": "node dist/server.js",
    "watch": "tsc -w",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "eval": "ts-node src/evals/cli.ts",
    "eval:benchmark": "ts-node src/evals/benchmark.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.66",
    "@anthropic-ai/sdk": "^0.78.0",
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@opentelemetry/auto-instrumentations-node": "^0.71.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@qdrant/js-client-rest": "^1.16.2",
    "@types/ioredis": "^4.28.10",
    "axios": "^1.6.0",
    "bullmq": "^5.71.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^4.18.2",
    "ioredis": "^5.9.2",
    "js-yaml": "^4.1.1",
    "p-limit": "^5.0.0",
    "prom-client": "^15.1.3",
    "protobufjs": "^8.0.0",
    "ts-morph": "^27.0.2",
    "uuid": "^9.0.0",
    "web-tree-sitter": "^0.26.7",
    "winston": "^3.19.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.0",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0"
  }
}
