# =============================================================================
# Reka RAG API Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# SECURITY: Never commit .env to version control!
# =============================================================================

# --- Server ---
API_PORT=3100
API_HOST=127.0.0.1          # Use 0.0.0.0 only inside Docker

# --- CORS ---
# Comma-separated list of allowed origins. Default: localhost:3000
# CORS_ORIGIN=http://localhost:3000,https://your-dashboard.example.com

# --- Authentication ---
# Set this to require API key on all requests (recommended for production)
# Generate with: node -e "console.log(require('crypto').randomUUID())"
# API_KEY=

# --- Qdrant Vector Database ---
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=             # Required for Qdrant Cloud

# --- Embedding Provider ---
# Options: bge-m3-server (default, self-hosted), ollama, openai
EMBEDDING_PROVIDER=bge-m3-server
BGE_M3_URL=http://localhost:8080
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-m3
# OPENAI_API_KEY=             # Required for openai provider

# --- LLM Provider ---
# Options: ollama (default, local), openai, anthropic
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen3.5:35b
OLLAMA_THINK=true
OLLAMA_THINK_BUDGET=8192
# OPENAI_API_KEY=             # Required for openai provider
# OPENAI_MODEL=gpt-4-turbo-preview
# ANTHROPIC_API_KEY=          # Required for anthropic provider
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Vector Dimensions ---
# Must match your embedding model: bge-m3=1024, openai=1536, ollama/nomic=768
VECTOR_SIZE=1024

# --- Redis (optional, enables caching) ---
REDIS_URL=redis://localhost:6380

# --- Logging ---
LOG_LEVEL=info               # error | warn | info | debug

# --- Confluence Integration (optional) ---
# CONFLUENCE_URL=https://your-domain.atlassian.net
# CONFLUENCE_EMAIL=
# CONFLUENCE_API_TOKEN=       # Generate at: https://id.atlassian.com/manage-profile/security/api-tokens

# --- Advanced: Memory Governance ---
# MEMORY_QUARANTINE_TTL_DAYS=7
# MEMORY_DECAY_RATE=0.10
# MEMORY_COMPACTION_THRESHOLD=0.85

# --- Advanced: Agent Runtime ---
# AGENT_OLLAMA_MODEL=qwen3.5:35b
# AGENT_MAX_ITERATIONS=8
# AGENT_TIMEOUT=180000

# --- Reka Cloud (hybrid mode) ---
# Set REKA_CLOUD_URL to proxy search/memory ops to managed cloud
# REKA_CLOUD_URL=https://api.reka.dev
# REKA_CLOUD_KEY=rk_live_team_...
# REKA_EDGE_ID=                   # Auto-generated if not set

# --- Billing (cloud mode only) ---
# REKA_BILLING_ENABLED=false
# API_KEYS=admin:rk_live_team_abc,ci:rk_live_starter_def
