# =============================================================================
# Reka RAG API Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# SECURITY: Never commit .env to version control!
# =============================================================================

# --- Server ---
API_PORT=3100
API_HOST=127.0.0.1          # Use 0.0.0.0 only inside Docker

# --- CORS ---
# Comma-separated list of allowed origins. Default: localhost:3000
# CORS_ORIGIN=http://localhost:3000,https://your-dashboard.example.com

# --- Authentication ---
# Set this to require API key on all requests (recommended for production)
# Generate with: node -e "console.log(require('crypto').randomUUID())"
# API_KEY=

# Dev only: bypass auth when no keys are configured (NEVER set in production).
# ALLOW_ANONYMOUS=true

# Admin token for /api/keys (mint/list/revoke keys). When unset, key management is
# only reachable from loopback (localhost). Set this in any deployment that terminates
# behind a reverse proxy, or those endpoints will reject all callers.
# ADMIN_API_KEY=

# --- Network / Proxy ---
# How many reverse-proxy hops to trust for req.ip / X-Forwarded-For. Default (unset or
# "false") trusts NOTHING — req.ip is the direct socket address and XFF is ignored, so
# clients cannot spoof their IP. Behind nginx/an LB set this to the hop count, e.g. "1".
# TRUST_PROXY=1

# --- Rate Limiting (requests/min) ---
# RATE_LIMIT_AUTH=10        # login/signup/waitlist (pre-auth brute-force surface)
# RATE_LIMIT_DEFAULT=100    # search, memory
# RATE_LIMIT_LLM=20         # ask, agent, review
# RATE_LIMIT_INDEXING=5     # index operations

# --- Incremental File Watcher (auto re-index changed files) ---
# Off by default. When enabled, watches WATCH_PATH and incrementally re-indexes
# changed/added/removed files into WATCH_PROJECT's codebase collection.
# FILE_WATCHER_ENABLED=true
# WATCH_PATH=/path/to/project        # directory to watch (node_modules/dist/.git ignored)
# WATCH_PROJECT=myproject            # project whose _codebase collection to update

# --- Qdrant Vector Database ---
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=             # Required for Qdrant Cloud

# --- Embedding Provider ---
# Options: bge-m3-server (default, self-hosted), ollama, openai
EMBEDDING_PROVIDER=bge-m3-server
BGE_M3_URL=http://localhost:8080
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-m3
# OPENAI_API_KEY=             # Required for openai provider

# --- LLM Provider ---
# Options: ollama (default, local), openai, anthropic
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen3.5:35b
OLLAMA_THINK=true
OLLAMA_THINK_BUDGET=8192
# OPENAI_API_KEY=             # Required for openai provider
# OPENAI_MODEL=gpt-4-turbo-preview
# ANTHROPIC_API_KEY=          # Required for anthropic provider
# ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Consolidation (M4, ADR-003) ---
# Route consolidation steps 1-2 (pattern detection, abstraction) to
# claude-opus-4-8 via the Message Batches API. Requires ANTHROPIC_API_KEY;
# off/absent -> sync Ollama path (default). Flag back off = instant revert.
# CONSOLIDATION_BATCH_ENABLED=false
# Coalescing window for batch rows (0 = submit immediately, batch-of-1):
# CONSOLIDATION_BATCH_WINDOW_MS=0

# --- Vector Dimensions ---
# Must match your embedding model: bge-m3=1024, openai=1536, ollama/nomic=768
VECTOR_SIZE=1024

# --- Redis (optional, enables caching) ---
REDIS_URL=redis://localhost:6380

# --- Logging ---
LOG_LEVEL=info               # error | warn | info | debug

# --- Advanced: Memory Governance ---
# MEMORY_QUARANTINE_TTL_DAYS=7
# MEMORY_DECAY_RATE=0.10
# MEMORY_COMPACTION_THRESHOLD=0.85

# --- Advanced: Agent Runtime ---
# AGENT_OLLAMA_MODEL=qwen3.5:35b
# AGENT_MAX_ITERATIONS=8
# AGENT_TIMEOUT=180000

# --- Reka Cloud (hybrid mode) ---
# Set REKA_CLOUD_URL to proxy search/memory ops to managed cloud
# REKA_CLOUD_URL=https://api.reka.dev
# REKA_CLOUD_KEY=rk_live_team_...
# REKA_EDGE_ID=                   # Auto-generated if not set

# --- Billing (cloud mode only) ---
# REKA_BILLING_ENABLED=false
# API_KEYS=admin:rk_live_team_abc,ci:rk_live_starter_def
